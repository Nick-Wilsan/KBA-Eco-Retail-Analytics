    create  table
      "warehouse"."silver"."silver_dim_store__dbt_tmp"
  
    as (
      WITH store_data AS (
    SELECT 
        CAST(store_id AS VARCHAR) AS store_id,
        store_city AS city,
        CAST(NULL AS VARCHAR) AS state -- Placeholder jika state tidak ada di retail_data
    FROM "warehouse"."warehouse"."stg_retail_data"
